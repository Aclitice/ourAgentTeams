# ourAgentTeams — Environment Variables Template
# Copy this file to .env and fill in your actual keys.
# .env is in .gitignore and will NEVER be committed.

# ── Cloud API Keys (optional — only needed for API worker models) ─────────────

# OpenAI (gpt-4o, gpt-4-turbo, etc.)
OPENAI_API_KEY=sk-...

# Anthropic (claude-3-5-sonnet, etc.)
ANTHROPIC_API_KEY=sk-ant-...

# Google (gemini-1.5-pro, etc.)
GOOGLE_API_KEY=AIzaSy...

# Mistral
MISTRAL_API_KEY=...

# Cohere
COHERE_API_KEY=...

# DeepSeek (cloud API, separate from local Ollama DeepSeek)
DEEPSEEK_API_KEY=...

# Azure OpenAI
AZURE_OPENAI_API_KEY=...
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-01

# ── Optional: disable Chroma RAG if first query fails (SSL / offline) ───────────
# OURAGENTTEAMS_DISABLE_RAG=1
